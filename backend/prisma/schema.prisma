generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model estados_tarea {
  id           BigInt         @id @default(autoincrement())
  nombre       String         @unique @db.VarChar(50)
  flujo_tareas flujo_tareas[]
  tareas       tareas[]
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model flujo_tareas {
  id                BigInt         @id @default(autoincrement())
  tarea_id          BigInt
  fecha             DateTime       @db.Date
  codigo_tarea      String?        @unique @db.VarChar(30)
  dia_semana        String?        @db.VarChar(10)
  semana            Int
  mes               Int
  anio              Int
  estado_id         BigInt?
  porcentaje_avance Decimal?       @db.Decimal(5, 2)
  observacion       String?
  estados_tarea     estados_tarea? @relation(fields: [estado_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  tareas            tareas         @relation(fields: [tarea_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model horarios {
  id       BigInt   @id @default(autoincrement())
  tarea_id BigInt?
  inicio   DateTime @db.Timestamptz(6)
  fin      DateTime @db.Timestamptz(6)
  tipo     String   @default("Planificado") @db.VarChar(20)
  tareas   tareas?  @relation(fields: [tarea_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model miembros {
  id        BigInt    @id @default(autoincrement())
  nombre    String    @db.VarChar(100)
  puesto    String    @db.VarChar(100)
  creado_en DateTime? @default(now()) @db.Timestamptz(6)
  tareas    tareas[]
}

model prioridades {
  id     BigInt   @id @default(autoincrement())
  nombre String   @unique @db.VarChar(50)
  tareas tareas[]
}

model proyectos {
  id          BigInt    @id @default(autoincrement())
  nombre      String    @db.VarChar(100)
  descripcion String?
  creado_en   DateTime? @default(now()) @db.Timestamptz(6)
  tareas      tareas[]
}

/// This model contains an expression index which requires additional setup for migrations. Visit https://pris.ly/d/expression-indexes for more info.
model tareas {
  id             BigInt         @id @default(autoincrement())
  proyecto_id    BigInt?
  miembro_id     BigInt?
  titulo         String         @db.VarChar(150)
  descripcion    String
  fecha_limite   DateTime       @db.Date
  estado_id      BigInt?
  prioridad_id   BigInt?
  creado_en      DateTime?      @default(now()) @db.Timestamptz(6)
  actualizado_en DateTime?      @default(now()) @db.Timestamptz(6)
  flujo_tareas   flujo_tareas[]
  horarios       horarios[]
  estados_tarea  estados_tarea? @relation(fields: [estado_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  miembros       miembros?      @relation(fields: [miembro_id], references: [id], onUpdate: NoAction)
  prioridades    prioridades?   @relation(fields: [prioridad_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  proyectos      proyectos?     @relation(fields: [proyecto_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([estado_id], map: "idx_tareas_estado")
  @@index([fecha_limite], map: "idx_tareas_fecha_limite")
  @@index([prioridad_id], map: "idx_tareas_prioridad")
}
