-- Crear base de datos
CREATE DATABASE gestion_tareas;
\c gestion_tareas;

-- Tabla de proyectos
CREATE TABLE proyectos (
    id SERIAL PRIMARY KEY,
    nombre VARCHAR(100) NOT NULL,
    descripcion TEXT,
    creado_en TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

-- Tabla de miembros
CREATE TABLE miembros (
    id SERIAL PRIMARY KEY,
    nombre VARCHAR(100) NOT NULL,
    puesto VARCHAR(100) NOT NULL,
    creado_en TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

-- Tabla de estados de tarea
CREATE TABLE estados_tarea (
    id SERIAL PRIMARY KEY,
    nombre VARCHAR(50) UNIQUE NOT NULL
);

-- Tabla de prioridades
CREATE TABLE prioridades (
    id SERIAL PRIMARY KEY,
    nombre VARCHAR(50) UNIQUE NOT NULL
);

-- Tabla de tareas
CREATE TABLE tareas (
    id SERIAL PRIMARY KEY,
    proyecto_id INT REFERENCES proyectos(id) ON DELETE CASCADE,
    miembro_id INT REFERENCES miembros(id) ON DELETE SET NULL,
    titulo VARCHAR(150) NOT NULL,
    descripcion TEXT NOT NULL,
    fecha_limite DATE NOT NULL,
    estado_id INT REFERENCES estados_tarea(id),
    prioridad_id INT REFERENCES prioridades(id),
    creado_en TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    actualizado_en TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

-- Trigger para actualizar automáticamente el campo actualizado_en
CREATE OR REPLACE FUNCTION actualizar_timestamp()
RETURNS TRIGGER AS $$
BEGIN
    NEW.actualizado_en = CURRENT_TIMESTAMP;
    RETURN NEW;
END;
$$ LANGUAGE plpgsql;

CREATE TRIGGER trg_actualizar_tareas
BEFORE UPDATE ON tareas
FOR EACH ROW
EXECUTE FUNCTION actualizar_timestamp();

-- Tabla de horarios
CREATE TYPE tipo_horario AS ENUM ('Planificado','Real','Reprogramado');

CREATE TABLE horarios (
    id SERIAL PRIMARY KEY,
    tarea_id INT REFERENCES tareas(id) ON DELETE CASCADE,
    inicio TIMESTAMP NOT NULL,
    fin TIMESTAMP NOT NULL,
    tipo tipo_horario DEFAULT 'Planificado'
);

-- Tabla de flujo de tareas
CREATE TYPE dia_semana AS ENUM ('Lunes','Martes','Miércoles','Jueves','Viernes','Sábado','Domingo');

CREATE TABLE flujo_tareas (
    id SERIAL PRIMARY KEY,
    tarea_id INT NOT NULL REFERENCES tareas(id) ON DELETE CASCADE,
    fecha DATE NOT NULL,
    codigo_tarea VARCHAR(30) UNIQUE,
    dia_semana dia_semana,
    semana INT NOT NULL,
    mes INT NOT NULL,
    anio INT NOT NULL,
    estado_id INT REFERENCES estados_tarea(id),
    porcentaje_avance NUMERIC(5,2),
    observacion TEXT
);

-- Índices optimizados
CREATE INDEX idx_tareas_fecha_limite ON tareas(fecha_limite);
CREATE INDEX idx_tareas_estado ON tareas(estado_id);
CREATE INDEX idx_tareas_prioridad ON tareas(prioridad_id);
CREATE INDEX idx_tareas_titulo ON tareas(titulo);

-- Para búsqueda en texto completo en descripcion
CREATE INDEX idx_tareas_descripcion ON tareas USING GIN (to_tsvector('spanish', descripcion));