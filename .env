## Template .env (safe defaults)
# Copy to .env locally and update credentials before running the project.

DATABASE_URL="postgresql://user:password@localhost:5432/gestion_tareas?schema=public"
BACKEND_PORT=3001
FRONTEND_PORT=5173
PORT=3001
NODE_ENV=development
# Frontend can use this (Vite variables must be prefixed with VITE_ when used in frontend code)
VITE_BACKEND_URL=http://localhost:3001
